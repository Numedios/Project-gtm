# =========================================
# FullEnrich API — Configuration
# =========================================

# URL de base de l'API
FULLENRICH_API_BASE_URL=https://app.fullenrich.com/api/v2

# Clé API
FULLENRICH_API_KEY=21390245-51ec-41ce-9db5-70e2019134f0

# Nombre max de contacts par requête bulk
FULLENRICH_BULK_LIMIT=100

# Timeout des requêtes (en secondes)
FULLENRICH_TIMEOUT=30

# Intervalle entre deux appels GET /bulk/{enrichment_id} (en secondes)
FULLENRICH_POLL_INTERVAL=15

# Nombre max de tentatives de polling avant timeout
FULLENRICH_POLL_MAX_ATTEMPTS=20

